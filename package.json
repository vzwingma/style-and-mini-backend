{
  "name": "api-style-mini-backend",
  "version": "2.0.0",
  "description": "Backend pour exposer les API Style & Mini",
  "main": "src/index.ts",
  "scripts": {
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "start": "npx ts-node src/app.ts",
    "debug": "nodemon src/app.ts",
    "dev": "dotenv-run-script .env .env.dev -- debug",
    "qua": "dotenv-run-script .env .env.qua -- start",
    "prod": "dotenv-run-script .env .env.prod -- start",
    "prebuild": "node scripts/generate-version.cjs",
    "build": "tsc --build",
    "postbuild": "node scripts/generate-dist-package.cjs",
    "start:dist": "node dist/app.js",
    "lint": "eslint --fix src test",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "Vincent Zwingmann",
  "repository": {
    "type": "git",
    "url": "https://github.com/vzwingma/style-and-mini-backend.git"
  },
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.873.0",
    "@aws-sdk/s3-request-presigner": "^3.873.0",
    "aws-lambda": "^1.0.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-basic-auth": "^1.2.1",
    "helmet": "^8.1.0",
    "mongodb": "^7.0.0",
    "morgan": "^1.10.1",
    "serverless-http": "^4.0.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.152",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.3.0",
    "@types/supertest": "^7.0.0",
    "dotenv-run-script": "^0.4.1",
    "@eslint/js": "^9.0.0",
    "eslint": "^10.0.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.9",
    "typescript-eslint": "^8.60.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.0"
  }
}
